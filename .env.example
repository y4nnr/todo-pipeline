# ── Postgres (superuser, container-only) ─────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-postgres-superuser
POSTGRES_DB=postgres

# ── Vikunja DB ───────────────────────────────────────────────────────────
VIKUNJA_DB_USER=vikunja_user
VIKUNJA_DB_PASSWORD=change-me-vikunja
VIKUNJA_DB_NAME=vikunja

# ── Vikunja app ──────────────────────────────────────────────────────────
VIKUNJA_JWT_SECRET=change-me-generate-with-openssl-rand-hex-32
VIKUNJA_PUBLIC_URL=http://localhost:3456
TZ=Europe/Paris

# ── Ingest DB ────────────────────────────────────────────────────────────
INGEST_DB_USER=ingest_user
INGEST_DB_PASSWORD=change-me-ingest
INGEST_DB_NAME=ingest
INGEST_DB_HOST=127.0.0.1
INGEST_DB_PORT=5432

# ── Google Cloud (Gmail + Pub/Sub) ───────────────────────────────────────
GCP_PROJECT_ID=your-gcp-project-id
PUBSUB_SUBSCRIPTION=gmail-todo-sub
GMAIL_USER=you@example.com
GMAIL_SUBJECT_PREFIX=[TODO]
# Path to the service-account or OAuth credentials JSON (mounted, not committed)
GOOGLE_APPLICATION_CREDENTIALS=/path/to/todo/ingest/secrets/gcp-sa.json
# OAuth user token (for Gmail API on behalf of GMAIL_USER)
GMAIL_OAUTH_TOKEN_PATH=/path/to/todo/ingest/secrets/gmail-token.json

# ── Anthropic ────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-haiku-4-5

# ── Vikunja API (for ingest → Vikunja) ───────────────────────────────────
VIKUNJA_API_URL=http://127.0.0.1:3456/api/v1
VIKUNJA_API_TOKEN=tk_...
VIKUNJA_DEFAULT_PROJECT_ID=1

# ── ntfy.sh alerting (error + heartbeat) ─────────────────────────────────
NTFY_TOPIC=your-unique-ntfy-topic
